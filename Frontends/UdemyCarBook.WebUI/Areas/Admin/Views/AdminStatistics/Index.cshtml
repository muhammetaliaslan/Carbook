@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">

        <!-- ================= ROW 1 ================= -->
        <div class="row mb-4">

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-primary border-primary h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Toplam Araç</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.v</h2>
                            <span class="text-white-50">@ViewBag.v1%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.v1%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-success border-success h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Lokasyon</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.locationCount</h2>
                            <span class="text-white-50">@ViewBag.locationCountRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.locationCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-dark border-dark h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Personel</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white">5</h2>
                            <span class="text-white-50">75%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:75%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-info border-info h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Blog</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white">8</h2>
                            <span class="text-white-50">62%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:62%;"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ================= ROW 2 ================= -->
        <div class="row mb-4">

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-primary border-primary h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Marka</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.brandCount</h2>
                            <span class="text-white-50">@ViewBag.brandCountRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.brandCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-success border-success h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Günlük Ortalama</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white">4350 ₺</h2>
                            <span class="text-white-50">68%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:68%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-dark border-dark h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Haftalık Ortalama</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white">30450 ₺</h2>
                            <span class="text-white-50">68%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:68%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-info border-info h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Aylık Ortalama</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white">130500 ₺</h2>
                            <span class="text-white-50">68%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:68%;"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ================= ROW 3 ================= -->
        <div class="row mb-4">

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-primary border-primary h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Otomatik Araç</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.carCountByTranmissionIsAuto</h2>
                            <span class="text-white-50">@ViewBag.carCountByTranmissionIsAutoRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.carCountByTranmissionIsAutoRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-success border-success h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">En Çok Marka</h5>
                        <div class="d-flex justify-content-between">
                            <h4 class="text-white">@ViewBag.brandNameByMaxCar</h4>
                            <span class="text-white-50">@ViewBag.brandNameByMaxCarRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.brandNameByMaxCarRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-dark border-dark h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">En İyi Blog</h5>
                        <div class="d-flex justify-content-between">
                            <h5 class="text-white">Güvenli Kullanım</h5>
                            <span class="text-white-50">85%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:85%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-info border-info h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">10.000 KM Altı</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.carCountByKmSmallerThen1000</h2>
                            <span class="text-white-50">@ViewBag.carCountByKmSmallerThen1000Random%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.carCountByKmSmallerThen1000Random%;"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ================= ROW 4 ================= -->
        <div class="row mb-4">

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-primary border-primary h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Benzin/Dizel</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.carCountByFuelGasolineOrDiesel</h2>
                            <span class="text-white-50">@ViewBag.carCountByFuelGasolineOrDieselRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.carCountByFuelGasolineOrDieselRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-success border-success h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">Elektrikli</h5>
                        <div class="d-flex justify-content-between">
                            <h2 class="text-white"># @ViewBag.carCountByFuelElectric</h2>
                            <span class="text-white-50">@ViewBag.carCountByFuelElectricRandom%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:@ViewBag.carCountByFuelElectricRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-dark border-dark h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">En Pahalı Araç</h5>
                        <div class="d-flex justify-content-between">
                            <h5 class="text-white">Mercedes E300</h5>
                            <span class="text-white-50">92%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:92%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4">
                <div class="card bg-info border-info h-100">
                    <div class="card-body p-4">
                        <h5 class="text-white">En Ucuz Araç</h5>
                        <div class="d-flex justify-content-between">
                            <h5 class="text-white">Fiat Egea</h5>
                            <span class="text-white-50">92%</span>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-light" style="width:92%;"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>